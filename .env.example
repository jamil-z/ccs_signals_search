# ============================================================
#  ICP Search Engine — .env.example
#  Copy this to .env and fill in your values
# ============================================================

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_API_KEY=your_key_here

# --- Search Backend (choose one or both) ---
# Get free key at https://serper.dev (2,500 searches/month free)
SERPER_API_KEY=your_serper_key_here

# Search backend: "serper" | "playwright" | "auto" (tries serper first, falls back to playwright)
SEARCH_BACKEND=serper

# --- Playwright (used when SEARCH_BACKEND=playwright or as fallback) ---
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_MS=30000

# --- Concurrency ---
MAX_CONCURRENT_COMPANIES=2

# --- Rate Limiting ---
BASE_REQUEST_DELAY_SECONDS=1.5
MAX_JITTER_SECONDS=1.5

# --- Paths ---
COMPANIES_FILE=./companies.txt
OUTPUT_DIR=./outputs

# --- Logging ---
LOG_LEVEL=INFO
